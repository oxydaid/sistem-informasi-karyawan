<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Block access to sensitive files
    RedirectMatch 404 /\.env
    RedirectMatch 404 /\.git
    RedirectMatch 404 /composer\.(json|lock)
    RedirectMatch 404 /package\.(json|lock)
    RedirectMatch 404 /pnpm-lock\.yaml
    RedirectMatch 404 /artisan
    RedirectMatch 404 /phpunit\.xml
    RedirectMatch 404 /Dockerfile
    RedirectMatch 404 /docker-compose.*

    # 2. Block access to sensitive directories
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor|whatsapp|supervisor|docker)($|/) - [F,L]

    # 3. Redirect remaining requests to the public/ directory
    RewriteRule ^$ public/ [L]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
